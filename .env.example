# Copy to .env and fill in your own values. NEVER commit the real .env.
# SLACK_BOT_TOKEN: your Slack bot token (the one Slack shows on your app's OAuth page).
SLACK_BOT_TOKEN=
LLM_ENDPOINT=http://127.0.0.1:8082/v1/chat/completions
LLM_MODEL=/path/to/model
ALFRED_RAG_ENDPOINT=http://localhost:9000/search
# Slack IDs (find yours in the Slack admin UI)
POSITIONS_CHANNEL=C0XXXXXXXXX
